# Frontier — Environment Variables
# Copy to .env.local for development

# Anthropic API key (used by Vercel edge function, not exposed to client)
ANTHROPIC_API_KEY=sk-ant-...

# Vercel KV store URL (for rate limiting in production)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Moonshot API key — use api.moonshot.ai (not .cn for international users)
# Working models: moonshot-v1-8k, moonshot-v1-32k, kimi-k2.5 (thinking model)
MOONSHOT_API_KEY=sk-...

# Google Gemini API key — fast and cheap, good for testing
GEMINI_API_KEY=AI...

# Narrator provider: 'moonshot' (default, cheaper) | 'gemini' | 'anthropic'
VITE_NARRATOR_PROVIDER=moonshot

# Deployed domain (for CORS enforcement)
VITE_APP_DOMAIN=http://localhost:3000

{
  "name": "frontier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A literary western survival game on the 1866 Goodnight-Loving Trail",
  "author": "Perry Martin",
  "repository": "https://github.com/pmartin1915/frontier",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "simulate": "npx tsx src/simulator/index.ts",
    "simulate:quick": "npx tsx src/simulator/index.ts --runs=10 --days=60",
    "simulate:full": "npx tsx src/simulator/index.ts --runs=50 --days=100 --strategy=optimal",
    "test:narrator": "npx tsx src/scripts/test-narrator.ts",
    "test:e2e": "npx playwright test",
    "test:visual": "npx playwright test e2e/visual-regression.spec.ts",
    "test:visual:update": "npx playwright test e2e/visual-regression.spec.ts --update-snapshots",
    "screenshot": "npx tsx src/scripts/screenshot.ts",
    "visual-audit": "npx tsx e2e/visual-audit-sweep.ts",
    "agent:state": "curl -s http://localhost:3000/api/agent/state | python -m json.tool",
    "agent:summary": "curl -s http://localhost:3000/api/agent/summary"
  },
  "dependencies": {
    "flexlayout-react": "^0.8.18",
    "howler": "^2.2.4",
    "phaser": "^3.80.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@tauri-apps/api": "^2.10.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@playwright/test": "^1.58.2",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vercel/node": "^5.6.18",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fake-indexeddb": "^6.2.5",
    "playwright": "^1.58.2",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
